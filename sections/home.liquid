{%- assign section_product = all_products[section.settings.product_handle] -%}
{%- if section_product == empty -%}{%- assign section_product = all_products["mushroom-fuse-coffee"] -%}{%- endif -%}

<div class="home-story">

<!-- ══════════════════════════════════
     CHAPTER 1 — THE AWAKENING
══════════════════════════════════ -->
<section class="st-ch" data-story style="--dur:4">
  <div class="st-sticky">
    <div class="st-ch1">
      <div class="st-ch1-brand" id="st-brand">PEAKASY</div>
      <p class="st-ch1-tag" id="st-tag">Clarity. Energy. Balance.</p>
      <div class="st-ch1-can" id="st-can">
        {%- if section_product.featured_image -%}
          <img src="{{ section_product.featured_image | img_url: 'master' }}" alt="{{ section_product.title }}">
        {%- else -%}
          <img src="{{ 'Mush-Coffe-trans.png' | asset_url }}" alt="Peakasy Mushroom Coffee">
        {%- endif -%}
      </div>
      <div class="st-ch1-cta" id="st-cta">
        <button class="btn-g" onclick="goOrder()">Get Peakasy — {{ section_product.price | money }}</button>
        <p class="st-scroll-hint">↓ &nbsp; Scroll to begin</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 2 — THE REALITY
══════════════════════════════════ -->
<section class="st-ch" data-story style="--dur:3">
  <div class="st-sticky">
    <div class="st-ch2">
      <p class="st-line" id="st-p1">Your coffee is holding you back.</p>
      <p class="st-line st-line--sub" id="st-p2">The afternoon crash. The anxiety. The dependency.</p>
      <p class="st-line st-line--q" id="st-p3">What if morning coffee could do more?</p>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 3 — THE ANSWER
══════════════════════════════════ -->
<section class="st-ch" data-story style="--dur:3">
  <div class="st-sticky">
    <div class="st-ch3">
      <div class="st-ch3-can" id="st-ans-can">
        {%- if section_product.featured_image -%}
          <img src="{{ section_product.featured_image | img_url: 'master' }}" alt="{{ section_product.title }}">
        {%- else -%}
          <img src="{{ 'Mush-Coffe-trans.png' | asset_url }}" alt="Peakasy">
        {%- endif -%}
      </div>
      <div class="st-ch3-text">
        <h2 class="st-ch3-name" id="st-ans-name">MUSHROOM FUSE</h2>
        <p class="st-ch3-ing" id="st-ans-ing">LION'S MANE &nbsp;•&nbsp; CHAGA &nbsp;•&nbsp; ARABICA</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 4 — THE INGREDIENTS
══════════════════════════════════ -->
<section class="st-ch" data-story style="--dur:4">
  <div class="st-sticky">
    <div class="st-ch4">
      <div class="st-ing" id="st-ing0">
        <span class="st-ing-sci">Hericium erinaceus</span>
        <h3 class="st-ing-name">Lion's Mane</h3>
        <p class="st-ing-ben">Grow new neural connections.</p>
      </div>
      <div class="st-ing" id="st-ing1">
        <span class="st-ing-sci">Inonotus obliquus</span>
        <h3 class="st-ing-name">Chaga</h3>
        <p class="st-ing-ben">Defend. Restore. Thrive.</p>
      </div>
      <div class="st-ing" id="st-ing2">
        <span class="st-ing-sci">Coffea arabica</span>
        <h3 class="st-ing-name">Arabica</h3>
        <p class="st-ing-ben">The ritual you already know.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 5 — THE RITUAL
══════════════════════════════════ -->
<section class="st-ch" data-story style="--dur:2.5">
  <div class="st-sticky">
    <div class="st-ch5">
      <p class="st-ch5-pre tag">How to Brew</p>
      <div class="st-step" data-at="0.05">
        <span class="st-step-n">01</span>
        <div class="st-step-body">
          <strong>Scoop</strong>
          <span>1 teaspoon into your mug.</span>
        </div>
      </div>
      <div class="st-step" data-at="0.3">
        <span class="st-step-n">02</span>
        <div class="st-step-body">
          <strong>Pour</strong>
          <span>8–10oz water at 160–175°F.</span>
        </div>
      </div>
      <div class="st-step" data-at="0.55">
        <span class="st-step-n">03</span>
        <div class="st-step-body">
          <strong>Stir</strong>
          <span>Dissolve completely in ~10 seconds.</span>
        </div>
      </div>
      <div class="st-step" data-at="0.78">
        <span class="st-step-n">04</span>
        <div class="st-step-body">
          <strong>Savour</strong>
          <span>Let clarity arrive.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 6 — THE PROOF
══════════════════════════════════ -->
<section class="st-ch" data-story style="--dur:2">
  <div class="st-sticky">
    <div class="st-ch6">
      <div class="st-rev" data-at="0.08">
        <div class="st-rev-stars">★★★★★</div>
        <blockquote class="st-rev-q">"3 months in and my focus is genuinely sharper. The 3pm crash is completely gone."</blockquote>
        <cite class="st-rev-by">Sarah K. &nbsp;—&nbsp; New York</cite>
      </div>
      <div class="st-rev" data-at="0.38">
        <div class="st-rev-stars">★★★★★</div>
        <blockquote class="st-rev-q">"The calm creative clarity is real. As a designer my output has notably improved."</blockquote>
        <cite class="st-rev-by">Elena M. &nbsp;—&nbsp; Berlin</cite>
      </div>
      <div class="st-rev" data-at="0.68">
        <div class="st-rev-stars">★★★★★</div>
        <blockquote class="st-rev-q">"Tried 6 mushroom coffees. This is the only one where I felt a genuine difference."</blockquote>
        <cite class="st-rev-by">Luca B. &nbsp;—&nbsp; Milan</cite>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 7 — THE OFFER (Order)
══════════════════════════════════ -->
<section class="order-sec" id="order-sec">
  <div class="os-hdr">
    <p class="tag">Order Now</p>
    <h2 class="h2">Your Ritual Awaits</h2>
    <p>Join 847+ customers — pick your quantity and feel the difference.</p>
  </div>
  <div class="os-wrap">
    <div class="os-card">
      <div class="os-top">
        <div class="os-l">
          <div class="cans-stage" id="cans-stage"></div>
          <div class="os-can-lbl" id="cans-lbl">1 × Mushroom Fuse</div>
          <div class="os-can-sub">Instant Coffee · 30 Servings · 1.9oz</div>
          <div class="os-mini-revs" id="mini-revs"></div>
        </div>
        <div class="os-r">
          <div>
            <div class="os-qty-lbl" style="margin-bottom:14px">Select Quantity</div>
            <div class="os-pills">
              <!-- 1 TIN -->
              <div class="osp sel" data-q="1" onclick="osPick(this,1)">
                <div class="osp-top">
                  <div class="osp-l"><div class="osp-chk">✓</div><div><div class="osp-n">1 Tin</div><div class="osp-d">Try it · 30 servings</div></div></div>
                  <div class="osp-r"><div class="osp-p">{{ section_product.price | money }}</div><div class="osp-pp">{{ section_product.price | divided_by: 30 | money }}/serving</div></div>
                </div>
                <div class="osp-bonuses">
                  <span class="osp-bon osp-bon-pdf">📘 Free 30-Day Guide</span>
                </div>
              </div>
              <!-- 2 TINS — FEATURED -->
              <div class="osp osp-feat" data-q="2" onclick="osPick(this,2)">
                <div class="osp-bdg osp-bdg-feat">🏆 Most Popular</div>
                <div class="osp-top">
                  <div class="osp-l"><div class="osp-chk"></div><div><div class="osp-n">2 Tins</div><div class="osp-d">60-day · The Sweet Spot</div></div></div>
                  <div class="osp-r"><div class="osp-p">{{ section_product.price | times: 2 | money }}</div><div class="osp-pp">{{ section_product.price | divided_by: 30 | money }}/serving</div></div>
                </div>
                <div class="osp-bonuses">
                  <span class="osp-bon osp-bon-pdf">📘 Free 30-Day Guide</span>
                  <span class="osp-bon osp-bon-caps">🍄 Lion's Mane Capsules</span>
                  <span class="osp-bon osp-bon-ship">🚚 Free Shipping</span>
                </div>
              </div>
              <!-- 3 TINS -->
              <div class="osp" data-q="3" onclick="osPick(this,3)">
                <div class="osp-bdg" style="background:var(--gl)">Best Value</div>
                <div class="osp-top">
                  <div class="osp-l"><div class="osp-chk"></div><div><div class="osp-n">3 Tins</div><div class="osp-d">90-day supply</div></div></div>
                  <div class="osp-r"><div class="osp-p">{{ section_product.price | times: 3 | money }}</div><div class="osp-pp">{{ section_product.price | divided_by: 30 | money }}/serving</div></div>
                </div>
                <div class="osp-bonuses">
                  <span class="osp-bon osp-bon-pdf">📘 Free 30-Day Guide</span>
                  <span class="osp-bon osp-bon-caps">🍄 Lion's Mane Capsules</span>
                  <span class="osp-bon osp-bon-ship">🚚 Free Shipping</span>
                  <span class="osp-bon osp-bon-mct">🌿 MCT Oil Powder</span>
                </div>
              </div>
            </div>
          </div>
          <div>
            <!-- PURCHASE TYPE TOGGLE -->
            <div class="sub-toggle">
              <button class="sub-opt active" id="sub-onetime" onclick="pkSetPurchaseType('onetime')">
                <span class="sub-opt-ico">🛒</span>
                <div class="sub-opt-body">
                  <div class="sub-opt-title">One-Time Purchase</div>
                  <div class="sub-opt-price" id="sub-price-ot">{{ section_product.price | money }}</div>
                </div>
              </button>
              <button class="sub-opt" id="sub-sub" onclick="pkSetPurchaseType('subscribe')">
                <div class="sub-badge-save">Save 10%</div>
                <span class="sub-opt-ico">🔄</span>
                <div class="sub-opt-body">
                  <div class="sub-opt-title">Subscribe &amp; Save</div>
                  <div class="sub-opt-price sub-price-green" id="sub-price-sub">{{ section_product.price | times: 0.9 | round | money }}<span class="sub-per">/mo</span></div>
                </div>
              </button>
            </div>
            <div class="sub-info" id="sub-info" style="display:none">
              <span class="sub-info-ico">🔄</span>
              <span>Ships every 30 days · Cancel anytime · No commitment</span>
            </div>
            <div id="sub-manage-link" style="display:none;margin-top:6px;text-align:center;">
              <a href="/account" style="font-size:.7rem;color:var(--muted);text-decoration:underline;text-underline-offset:2px;">Manage or cancel subscription →</a>
            </div>

            <div class="os-sum">
              <div class="os-sr"><span>Subtotal</span><span id="os-sub">{{ section_product.price | money }}</span></div>
              <div class="os-sr sub-savings-row" id="sub-savings-row" style="display:none"><span style="color:#5a9a5a">Subscription Savings</span><span id="sub-savings-amt" style="color:#5a9a5a">−{{ section_product.price | times: 0.1 | round | money }}</span></div>
              <div class="os-sr"><span>Shipping</span><span id="os-ship" style="color:#5a9a5a">Free</span></div>
              <div class="os-sr"><span style="font-weight:600;color:var(--text)">Total</span><span class="os-tot" id="os-tot">{{ section_product.price | money }}</span></div>
            </div>
            {%- assign sec_prod = all_products[section.settings.product_handle] -%}
            {%- assign sec_variant = sec_prod.first_available_variant -%}
            {%- if sec_variant -%}
              {%- form 'product', sec_prod, id: 'pk-atc-form' -%}
                <input type="hidden" name="id" id="pk-variant-id" value="{{ sec_variant.id }}">
                <input type="hidden" name="quantity" id="pk-qty" value="1">
                <div class="subscriptions_app_embed_block"></div>
                {%- assign sub_plan = sec_prod.selling_plan_groups.first.selling_plans.first -%}
                <input type="hidden" name="" id="pk-selling-plan" value="{{ sub_plan.id | default: '' }}">
                <button type="submit" class="os-cta" id="pk-atc-btn">
                  <span id="os-cta-t">Add 1 Tin to Cart</span><span class="os-arr">→</span>
                </button>
                <button type="button" class="os-cta os-cta-buy" id="pk-buy-btn" onclick="pkBuyNow()">
                  <span id="os-buy-t">Buy Now</span><span class="os-arr">⚡</span>
                </button>
                <div class="os-express">{{ form | payment_button }}</div>
              {%- endform -%}
            {%- else -%}
              <button class="os-cta" onclick="addToCart()">
                <span id="os-cta-t">Add 1 Tin to Cart</span><span class="os-arr">→</span>
              </button>
              <button class="os-cta os-cta-buy" onclick="pkBuyNow()">
                <span>Buy Now</span><span class="os-arr">⚡</span>
              </button>
            {%- endif -%}
            <div class="os-micro"><span>🔒 Secure</span><span>↩️ 30-day returns</span><span>🚚 Ships 1-2 days</span></div>
          </div>
        </div>
      </div>
      <div class="os-bar">
        <div class="os-rat"><div class="os-sc">4.9</div><div><div class="os-st">★★★★★</div><div class="os-rc">847 reviews</div></div></div>
        <div class="os-revs" id="os-revs"></div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 8 — FAQ
══════════════════════════════════ -->
<section class="faq-sec">
  <div class="faq-inner">
    <div class="faq-hdr"><p class="tag">Questions</p><h2 class="h2">FAQ</h2></div>
    <div class="fi"><div class="fq" onclick="faq(this)">What does it taste like?<span class="fa-arr">▼</span></div><div class="fa">Rich, smooth, chocolate-forward — premium medium roast with subtle earthy depth. Most customers say it tastes better than regular coffee.</div></div>
    <div class="fi"><div class="fq" onclick="faq(this)">How much caffeine per serving?<span class="fa-arr">▼</span></div><div class="fa">Approximately 60-80mg — same as a regular cup, but adaptogens smooth the energy curve for a jitter-free experience.</div></div>
    <div class="fi"><div class="fq" onclick="faq(this)">Is it vegan and gluten-free?<span class="fa-arr">▼</span></div><div class="fa">Yes! 100% vegan, gluten-free, non-GMO. No fillers, no additives — just coffee and mushrooms.</div></div>
    <div class="fi"><div class="fq" onclick="faq(this)">How long does one tin last?<span class="fa-arr">▼</span></div><div class="fa">~30 servings per tin. Consume within 3 months of opening, or store airtight for up to 1 year.</div></div>
    <div class="fi"><div class="fq" onclick="faq(this)">Can I use it with milk?<span class="fa-arr">▼</span></div><div class="fa">Absolutely — oat, almond, or whole milk all work beautifully. Use 2 scoops for a stronger brew.</div></div>
    <div class="fi"><div class="fq" onclick="faq(this)">When will I see results?<span class="fa-arr">▼</span></div><div class="fa">Many notice improved focus within the first week. For deeper benefits, consistent daily use over 4-6 weeks is recommended.</div></div>
  </div>
</section>

<!-- ══════════════════════════════════
     CHAPTER 9 — FOOTER
══════════════════════════════════ -->
<div class="cta-ban"><p class="tag">Ready to Peak?</p><h2 class="h2">Start Your Ritual Today</h2><p>Join 847+ customers who upgraded their morning coffee.</p><button class="btn-g" onclick="goOrder()">Get Peakasy — {{ section_product.price | money }} →</button></div>

<footer>
  <div class="ft">
    <div class="ft-brand"><span class="n-logo-text" style="font-size:1.1rem;color:var(--foot-text)">Peakasy</span><p class="ft-desc">Ancient mushroom wisdom meets modern coffee craft. Fuel your focus, naturally.</p></div>
    <div class="ft-col"><h4>Shop</h4><a onclick="goOrder()">Mushroom Fuse Coffee</a><a href="/cart">Cart</a></div>
    <div class="ft-col"><h4>Company</h4><a href="/pages/about-us">About Us</a><a>Blog</a></div>
    <div class="ft-col"><h4>Policies</h4><a href="/policies/shipping-policy">Shipping Policy</a><a href="/pages/refund-policy">Refund Policy</a><a href="/policies/terms-of-service">Terms of Service</a><a href="/policies/privacy-policy">Privacy Policy</a><a href="/policies/purchase-options-cancellation-policy">Cancellation Policy</a></div>
    <div class="ft-col"><h4>Support</h4><a>FAQ</a><a>Contact Us</a></div>
  </div>
  <div class="ft-btm"><span>© 2026 Peakasy. All rights reserved.</span><span>Focus · Energy · Balance</span></div>
</footer>

</div>

{% schema %}
{"name":"Home Page","tag":"div","class":"home-wrap","settings":[{"type":"text","id":"product_handle","label":"Product URL handle","info":"Find in Shopify Admin → Products → click your product → the last part of the URL","default":"mushroom-fuse-coffee"}]}
{% endschema %}
