                  <div class="osp-l"><div class="osp-chk"></div><div><div class="osp-n">3 Tins</div><div class="osp-d">90-day supply</div></div></div>
                  <div class="osp-r"><div class="osp-p">{{ section_product.price | times: 3 | money }}</div><div class="osp-pp">{{ section_product.price | divided_by: 30 | money }}/serving</div></div>
                </div>
                <div class="osp-bonuses">
