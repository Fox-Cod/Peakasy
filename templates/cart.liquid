{%- assign free_thresh_cents = 4000 -%}
{%- assign remaining = free_thresh_cents | minus: cart.total_price -%}

<div style="max-width:720px;margin:90px auto;padding:0 24px 80px;" id="cart-page">

  <h1 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:700;color:var(--text);margin-bottom:6px;">Your Cart</h1>
  <p style="color:var(--text2);font-size:.85rem;margin-bottom:28px;" id="cart-count-label">
    {{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }}
  </p>

  {%- if cart.item_count == 0 -%}
    <div style="text-align:center;padding:60px 0;">
      <div style="font-size:3.5rem;margin-bottom:16px;">☕</div>
      <p style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:700;color:var(--text);margin-bottom:10px;">Your cart is empty</p>
      <p style="color:var(--text2);margin-bottom:28px;">Start your ritual.</p>
      <a href="/" class="btn-g" style="text-decoration:none;display:inline-block;padding:14px 32px;">Shop Now</a>
    </div>

  {%- else -%}

    {%- if remaining > 0 -%}
      <div style="background:rgba(200,169,110,.08);border:1px solid rgba(200,169,110,.2);border-radius:10px;padding:12px 16px;margin-bottom:24px;font-size:.85rem;color:var(--gold);">
        Add {{ remaining | money }} more for <strong>free shipping</strong>
      </div>
    {%- else -%}
      <div style="background:rgba(90,154,90,.08);border:1px solid rgba(90,154,90,.2);border-radius:10px;padding:12px 16px;margin-bottom:24px;font-size:.85rem;color:#5a9a5a;">
        ✓ You qualify for <strong>free shipping!</strong>
      </div>
    {%- endif -%}

    <!-- Cart items — updated via Ajax, no page reload -->
    <div id="cart-items">
      {%- for item in cart.items -%}
      <div class="cart-item" data-key="{{ item.key }}" style="display:flex;gap:14px;align-items:flex-start;padding:18px 0;border-bottom:1px solid var(--bor);">
        <a href="{{ item.url }}" style="flex-shrink:0;display:block;width:76px;height:76px;background:var(--surf);border-radius:10px;overflow:hidden;">
          <img src="{{ item.image | img_url: '160x160' }}" alt="{{ item.title | escape }}"
            style="width:100%;height:100%;object-fit:contain;mix-blend-mode:screen;">
        </a>
        <div style="flex:1;min-width:0;">
          <a href="{{ item.url }}" style="text-decoration:none;font-weight:600;color:var(--text);font-size:.95rem;display:block;margin-bottom:3px;">{{ item.product.title }}</a>
          {%- unless item.variant.title == 'Default Title' -%}
            <div style="font-size:.78rem;color:var(--muted);margin-bottom:4px;">{{ item.variant.title }}</div>
          {%- endunless -%}
          {%- if item.selling_plan_allocation -%}
            <div style="display:inline-flex;align-items:center;gap:5px;font-size:.72rem;font-weight:600;color:var(--gold);background:rgba(200,169,110,.1);border:1px solid rgba(200,169,110,.25);border-radius:20px;padding:3px 10px;margin-bottom:6px;">🔄 Subscribe &amp; Save</div>
          {%- endif -%}
          <div style="font-size:.78rem;color:var(--muted);margin-bottom:8px;">{{ item.variant.sku }}</div>
          <div style="display:flex;align-items:center;gap:12px;margin-top:8px;">
            <!-- Qty controls — Ajax -->
            <div style="display:flex;align-items:center;border:1.5px solid var(--bor);border-radius:8px;overflow:hidden;">
              <button
                onclick="cartUpdateQty('{{ item.key }}', {{ item.quantity | minus: 1 }}, this)"
                style="width:34px;height:34px;background:none;border:none;color:var(--text);cursor:pointer;font-size:1.1rem;line-height:1;"
                aria-label="Decrease">−</button>
              <span class="cart-qty-display" style="padding:0 12px;color:var(--text);font-size:.88rem;font-weight:600;border-left:1px solid var(--bor);border-right:1px solid var(--bor);height:34px;display:flex;align-items:center;min-width:36px;justify-content:center;">{{ item.quantity }}</span>
              <button
                onclick="cartUpdateQty('{{ item.key }}', {{ item.quantity | plus: 1 }}, this)"
                style="width:34px;height:34px;background:none;border:none;color:var(--text);cursor:pointer;font-size:1.1rem;line-height:1;"
                aria-label="Increase">+</button>
            </div>
            <!-- Remove — Ajax -->
            <button
              onclick="cartRemoveItem('{{ item.key }}', this)"
              style="font-size:.75rem;color:var(--muted);text-decoration:underline;background:none;border:none;cursor:pointer;padding:0;">
              Remove
            </button>
          </div>
        </div>
        <div style="font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:700;color:var(--gold);flex-shrink:0;" class="cart-line-price">
          {{ item.line_price | money }}
        </div>
      </div>
      {%- endfor -%}
    </div>

    <!-- Summary -->
    <div style="padding:22px 0 0;">
      <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
        <span style="color:var(--text2);font-size:.9rem;">Subtotal</span>
        <span style="font-weight:700;color:var(--text);" id="cart-subtotal">{{ cart.total_price | money }}</span>
      </div>
      <p style="font-size:.78rem;color:var(--muted);margin-bottom:22px;">Taxes and shipping calculated at checkout</p>

      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <a href="/" style="flex:1;min-width:130px;text-align:center;padding:14px 20px;border:1.5px solid var(--bor);border-radius:50px;color:var(--text);text-decoration:none;font-size:.88rem;font-weight:600;transition:all .2s;">← Continue</a>


      </div>

      <!-- Checkout: simple link — Shopify reads cart from session, no POST needed -->
      <a href="/checkout"
        style="display:block;width:100%;text-align:center;background:var(--gold);color:#0a0907;border-radius:50px;padding:15px 24px;font-size:.95rem;font-weight:700;cursor:pointer;letter-spacing:.04em;transition:background .2s;text-decoration:none;margin-top:10px;box-sizing:border-box;">
        Checkout →
      </a>

      <!-- Express pay (Apple Pay, Shop Pay) — Shopify native -->
      {%- form 'cart', cart -%}
        <div style="margin-top:10px;">{{ form | payment_button }}</div>
      {%- endform -%}
    </div>

  {%- endif -%}
</div>

<script>
// ── Ajax cart helpers (cart page only) ──

function cartUpdateQty(key, newQty, triggerEl) {
  // Never go below 1 — use cartRemoveItem to delete
  if (newQty < 1) newQty = 1;

  var row = triggerEl.closest('.cart-item');
  if (row) row.style.opacity = '0.5';

  fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: key, quantity: newQty })
  })
  .then(function(r) { return r.json(); })
  .then(function(cart) {
    cartPageRerender(cart);
  })
  .catch(function() {
    if (row) row.style.opacity = '1';
    alert('Could not update cart. Please refresh.');
  });
}

function cartRemoveItem(key, triggerEl) {
  var row = triggerEl.closest('.cart-item');
  if (row) { row.style.opacity = '0.4'; row.style.pointerEvents = 'none'; }

  fetch('/cart/change.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: key, quantity: 0 })
  })
  .then(function(r) { return r.json(); })
  .then(function(cart) {
    cartPageRerender(cart);
  })
  .catch(function() {
    if (row) { row.style.opacity = '1'; row.style.pointerEvents = ''; }
    alert('Could not remove item. Please refresh.');
  });
}

function cartPageRerender(cart) {
  // Update badge in nav
  var cb = document.getElementById('cb');
  if (cb) { cb.textContent = cart.item_count; cb.className = 'bdg' + (cart.item_count > 0 ? ' on' : ''); }

  // Update count label
  var lbl = document.getElementById('cart-count-label');
  if (lbl) lbl.textContent = cart.item_count + (cart.item_count === 1 ? ' item' : ' items');

  // If cart is empty — reload to show empty state template
  if (cart.item_count === 0) {
    window.location.reload();
    return;
  }

  // Update subtotal
  var sub = document.getElementById('cart-subtotal');
  if (sub) sub.textContent = formatMoney(cart.total_price);

  // Rebuild items list from JSON (avoids key-mismatch bugs)
  var container = document.getElementById('cart-items');
  if (!container) return;

  var html = '';
  cart.items.forEach(function(item) {
    var img = item.image || '';
    var variantHtml = (item.variant_title && item.variant_title !== 'Default Title')
      ? '<div style="font-size:.78rem;color:var(--muted);margin-bottom:4px;">' + escHtml(item.variant_title) + '</div>'
      : '';
    var subBadge = item.selling_plan_allocation
      ? '<div style="display:inline-flex;align-items:center;gap:5px;font-size:.72rem;font-weight:600;color:var(--gold);background:rgba(200,169,110,.1);border:1px solid rgba(200,169,110,.25);border-radius:20px;padding:3px 10px;margin-bottom:6px;">🔄 Subscribe &amp; Save</div>'
      : '';
    var skuHtml = item.sku
      ? '<div style="font-size:.78rem;color:var(--muted);margin-bottom:8px;">' + escHtml(item.sku) + '</div>'
      : '';

    html += '<div class="cart-item" data-key="' + escHtml(item.key) + '" style="display:flex;gap:14px;align-items:flex-start;padding:18px 0;border-bottom:1px solid var(--bor);">';
    html +=   '<a href="/products/' + escHtml(item.handle) + '" style="flex-shrink:0;display:block;width:76px;height:76px;background:var(--surf);border-radius:10px;overflow:hidden;">';
    html +=     '<img src="' + img + '" alt="' + escHtml(item.title) + '" style="width:100%;height:100%;object-fit:contain;mix-blend-mode:screen;">';
    html +=   '</a>';
    html +=   '<div style="flex:1;min-width:0;">';
    html +=     '<a href="/products/' + escHtml(item.handle) + '" style="text-decoration:none;font-weight:600;color:var(--text);font-size:.95rem;display:block;margin-bottom:3px;">' + escHtml(item.product_title) + '</a>';
    html +=     variantHtml + subBadge + skuHtml;
    html +=     '<div style="display:flex;align-items:center;gap:12px;margin-top:8px;">';
    html +=       '<div style="display:flex;align-items:center;border:1.5px solid var(--bor);border-radius:8px;overflow:hidden;">';
    html +=         '<button onclick="cartUpdateQty(\'' + escHtml(item.key) + '\',' + (item.quantity - 1) + ',this)" style="width:34px;height:34px;background:none;border:none;color:var(--text);cursor:pointer;font-size:1.1rem;line-height:1;" aria-label="Decrease">−</button>';
    html +=         '<span class="cart-qty-display" style="padding:0 12px;color:var(--text);font-size:.88rem;font-weight:600;border-left:1px solid var(--bor);border-right:1px solid var(--bor);height:34px;display:flex;align-items:center;min-width:36px;justify-content:center;">' + item.quantity + '</span>';
    html +=         '<button onclick="cartUpdateQty(\'' + escHtml(item.key) + '\',' + (item.quantity + 1) + ',this)" style="width:34px;height:34px;background:none;border:none;color:var(--text);cursor:pointer;font-size:1.1rem;line-height:1;" aria-label="Increase">+</button>';
    html +=       '</div>';
    html +=       '<button onclick="cartRemoveItem(\'' + escHtml(item.key) + '\',this)" style="font-size:.75rem;color:var(--muted);text-decoration:underline;background:none;border:none;cursor:pointer;padding:0;">Remove</button>';
    html +=     '</div>';
    html +=   '</div>';
    html +=   '<div style="font-family:\'Cormorant Garamond\',serif;font-size:1.35rem;font-weight:700;color:var(--gold);flex-shrink:0;" class="cart-line-price">' + formatMoney(item.line_price) + '</div>';
    html += '</div>';
  });

  container.innerHTML = html;
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function formatMoney(cents) {
  return '$' + (cents / 100).toFixed(2);
}
</script>
